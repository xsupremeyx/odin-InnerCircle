<%- include("../partials/header", { title: title }) %>
<div class="page-container form-page">
<a href="/messages/<%= data.id %>" class="back-link">← Back to message</a>
<h1>Edit Message</h1>

<%- include("../partials/error") %>

<form action="/messages/<%= data.id %>/edit" method="POST">
    <input
        type="text"
        name="title"
        value="<%= data.title || '' %>"
        required
    >

    <textarea name="content" required><%= data.content || '' %></textarea>

    <button type="submit" class="btn">Update</button>
</form>
</div>
<%- include("../partials/footer") %>