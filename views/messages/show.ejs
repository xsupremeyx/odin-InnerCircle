<%- include("../partials/header", { title: title }) %>

<div class="page-container">

    <h1><%= message.title %></h1>

    <p><%= message.content %></p>

    <% if (locals.currentUser) { %>
        <small>
            Posted by <%= message.username %>
            on <%= message.created_at %>
        </small>
    <% } %>

    <% if (locals.currentUser && (locals.currentUser.id === message.user_id || locals.currentUser.is_admin)) { %>

        <a href="/messages/<%= message.id %>/edit">Edit</a>

        <form action="/messages/<%= message.id %>/delete" method="POST" >
            <button type="submit" onclick="return confirm('Are you sure you want to delete this message?');">Delete</button>
        </form>

    <% } %>

</div>

<%- include("../partials/footer") %>