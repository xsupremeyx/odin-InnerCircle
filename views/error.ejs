<%- include("partials/header", { title: "Error" }) %>

<div class="page-container">

    <h1>Something went wrong</h1>

    <p><%= message %></p>

    <% if (error && error.stack) { %>
        <pre><%= error.stack %></pre>
    <% } %>

    <a href="/">Go back home</a>

</div>

